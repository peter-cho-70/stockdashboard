# StockMind 환경변수 설정
# 이 파일을 복사해서 .env 로 저장 후 실제 값 입력
# cp .env.example .env

# ── 한국투자증권 Open API ──────────────────────────
# https://apiportal.koreainvestment.com 에서 발급
KIS_APP_KEY=your_kis_app_key
KIS_APP_SECRET=your_kis_app_secret
KIS_ACCOUNT_NO=12345678-01
KIS_IS_MOCK=true   # 모의투자: true / 실전투자: false

# ── Google Gemini AI (YouTube 문서 추출) ─────────
# https://aistudio.google.com 에서 발급 (무료)
GEMINI_API_KEY=your_gemini_api_key

# ── OpenAI GPT (종목·매크로·섹터 분석) ───────────
# https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# ── YouTube Data API ────────────────────────────
# https://console.cloud.google.com 에서 발급 (선택)
YOUTUBE_API_KEY=

# ── 데이터베이스 ────────────────────────────────
DB_PATH=./stockmind.db

# ── 알림 설정 ───────────────────────────────────
ALERT_THRESHOLD=5.0     # 5% 변동 시 알림
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=             # 이메일 알림 (선택)
SMTP_PASSWORD=          # Gmail 앱 비밀번호 (선택)

# ── 앱 설정 ────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false
