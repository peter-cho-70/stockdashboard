# StockMind 환경변수 설정
# 이 파일을 복사해서 .env 로 저장 후 실제 값 입력
# cp .env.example .env

# ── 한국투자증권 Open API ──────────────────────────
# https://apiportal.koreainvestment.com 에서 발급
KIS_APP_KEY=your_kis_app_key
KIS_APP_SECRET=your_kis_app_secret
KIS_ACCOUNT_NO=12345678-01
KIS_IS_MOCK=true   # 모의투자: true / 실전투자: false

# AI Studio: https://aistudio.google.com/apikey
# 형식: AIzaSy... (일반) 또는 AQ.... (서비스 계정 바인딩, 2025~)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_EXTRACT_MODEL=gemini-3.1-flash-lite
GEMINI_PROMPT_CACHE=false             # 무료 tier는 context cache 미지원
GEMINI_CACHE_TTL=3600s

# ── Anthropic Claude (기본 구조화 분석) ──────────
# https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-3-5-haiku-latest
ANALYSIS_PROVIDER=gemini

# ── AI 호출 절약 ─────────────────────────────────
AI_FALLBACK=false                  # false=선택 provider만, true=429 quota 시에만 fallback
AI_SKIP_IF_CACHED=true             # 이미 분석된 URL/원인은 DB 반환
ENABLE_BULK_YOUTUBE_ANALYZE=false  # 채널 일괄 분석 비활성 (개별 클릭만)

# ── OpenAI GPT (분석 옵션) ───────────────────────
# https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# ── YouTube Data API ────────────────────────────
# https://console.cloud.google.com 에서 발급 (선택)
YOUTUBE_API_KEY=

# ── 데이터베이스 ────────────────────────────────
DB_PATH=./stockmind.db

# ── 데모 모드 (공개 URL용 — backend/data/demo_portfolio.json) ──
DEMO_MODE=false
# 설정 화면에서 토글 시 PIN (서버 .env만, 클라이언트에 노출하지 않음)
DEMO_PIN=

# ── 알림 설정 ───────────────────────────────────
ALERT_THRESHOLD=5.0     # 5% 변동 시 알림
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=             # 이메일 알림 (선택)
SMTP_PASSWORD=          # Gmail 앱 비밀번호 (선택)

# ── 앱 설정 ────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false
